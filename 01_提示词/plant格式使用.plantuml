@startuml LangChain_TS_学习路线架构图

!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle
skinparam packageStyle rectangle

title LangChain TypeScript 学习路线架构图

package "阶段1: 基础入门 (1-2周)" #E3F2FD {
    [Node.js 18+] as node
    [TypeScript 配置] as ts
    [ChatOpenAI\nChatAnthropic] as models
    [Prompt Templates\nChatPromptTemplate] as prompts
    [Output Parsers\nString/Structured] as parsers
    [LCEL 管道语法 |] as lcel

    node --> ts
    ts --> models
    models --> prompts
    prompts --> parsers
    parsers --> lcel
}

package "阶段2: 核心组件 (2-3周)" #E8F5E9 {
    [Memory 系统\nBuffer/Window/Summary] as memory
    [Document Loaders\nPDF/CSV/Text] as loaders
    [Text Splitters\nRecursiveCharacter] as splitters
    [Embeddings\nOpenAI/Ollama] as embeddings
    [Vector Stores\nPinecone/Chroma] as vectorstores
    [Retrievers\nSimilarity/MMR] as retrievers
    [RAG Chain] as rag
    [Tools\nDynamic/Structured] as tools
    [Agents\nReAct/Plan-Execute] as agents

    memory --> agents
    loaders --> splitters
    splitters --> embeddings
    embeddings --> vectorstores
    vectorstores --> retrievers
    retrievers --> rag
    tools --> agents
}

package "阶段3: LangGraph (2-3周)" #FFF3E0 {
    [StateGraph] as graph
    [State 定义\nInterface/Type] as state
    [Nodes\nFunction/Runnable] as nodes
    [Edges\n普通/条件] as edges
    [Checkpointer\n内存/Postgres] as checkpointer
    [Human-in-the-Loop] as hitl
    [Subgraphs] as subgraphs

    state --> graph
    graph --> nodes
    nodes --> edges
    edges --> checkpointer
    checkpointer --> hitl
    hitl --> subgraphs
}

package "阶段4: 生产化 (2-3周)" #F3E5F5 {
    [流式处理\nstream/streamEvents] as streaming
    [LangSmith 监控] as langsmith
    [Callbacks 系统] as callbacks
    [MCP 协议集成] as mcp
    [部署优化\nEdge/Serverless] as deploy

    streaming --> langsmith
    langsmith --> callbacks
    callbacks --> mcp
    mcp --> deploy
}

' 连接各阶段
lcel --> memory : 进阶
rag --> graph : 升级
agents --> graph : 重构
subgraphs --> streaming : 优化

@enduml